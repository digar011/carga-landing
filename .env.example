# ==============================================
# CarGA — Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ==============================================

# --- Supabase (Required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (Required for "Ingresar con Google" on transportista side) ---
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# --- Google Maps Platform (Required for map features) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# --- WhatsApp Business API (Required for notifications) ---
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token

# --- Mercado Pago (Required for payments) ---
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key

# --- Firebase (Push notifications) ---
FIREBASE_SERVER_KEY=your-firebase-server-key
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"..."}

# --- Resend (Transactional email) ---
RESEND_API_KEY=re_your-resend-api-key

# --- Sentry (Error monitoring) ---
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# --- PostHog (Analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Claude API (Phase 2 — AI pricing) ---
# ANTHROPIC_API_KEY=sk-ant-your-key

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
